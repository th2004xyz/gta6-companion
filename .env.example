# Resend 邮件服务配置（P1 阶段邮件订阅）
# 获取地址：https://resend.com/api-keys
# 开发环境留空即可（API 会模拟成功）
RESEND_API_KEY=
RESEND_AUDIENCE_ID=

# 站点 URL（用于 SEO metadataBase，部署时替换为真实域名）
# NEXT_PUBLIC_SITE_URL=https://gta6-companion.example.com

# ─── Cloudflare 部署环境变量说明 ───────────────────────────
# 本项目通过 @opennextjs/cloudflare 部署到 Cloudflare Workers。
# 两类环境变量的配置方式不同：
#
# 1) 服务端密钥（运行时读取，构建时不可见）：
#    RESEND_API_KEY、RESEND_AUDIENCE_ID
#    在 Cloudflare Dashboard → Workers & Pages → 选中项目 →
#    Settings → Variables and Secrets 中以 “Secret” 类型添加；
#    或本地用 `npx wrangler secret put RESEND_API_KEY` 写入。
#    本地预览（npm run preview:cf）时把同名变量放进 .dev.vars。
#
# 2) 构建期变量（Next.js 在构建时内联，必须构建前就绪）：
#    NEXT_PUBLIC_SITE_URL
#    在 Cloudflare Dashboard → Workers Builds → Settings →
#    Build environment variables 中添加（明文即可，非 Secret）。
#    本地构建前写入 .env.local。
#
# .dev.vars 已在 .gitignore 中，勿提交真实密钥。
